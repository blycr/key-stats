{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run patch:wails && vite",
    "build": "vite build && bun run patch:wails",
    "preview": "vite preview",
    "patch:wails": "node -e \"const fs=require('fs'),f='wailsjs/go/app/App.js';if(fs.existsSync(f)){let c=fs.readFileSync(f,'utf8');if(c.includes('@ts-check')){fs.writeFileSync(f,c.replace('// @ts-check','// @ts-nocheck'));console.log('Patched '+f);}}\""
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.0.2",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "svelte": "^4.2.12",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4"
  }
}
