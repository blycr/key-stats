# KeyStats Configuration
# ======================
# Copy this file to .env and edit values below.
# Changes take effect on next launch.

# Window Size (last known dimensions)
WINDOW_WIDTH=1280
WINDOW_HEIGHT=800

# Appearance — dark | light | auto
THEME=dark

# Behavior
START_MINIMIZED=false
AUTO_START=false

# Data Storage — set to true to store data next to the executable
# PORTABLE_MODE=false
